{
  "expo": {
    "name": "SampleFinder",
    "slug": "samplefinder-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "buildNumber": "44",
      "supportsTablet": true,
      "bundleIdentifier": "com.samplefinder.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show nearby events and stores.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to show nearby events and stores.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload profile pictures.",
        "NSCameraUsageDescription": "This app needs access to your camera to take profile pictures."
      },
      "usesAppleSignIn": false,
      "appleTeamId": "AYNR8DRWG3",
      "associatedDomains": ["applinks:samplefinder.com"]
    },
    "android": {
      "icon": "./src/assets/icon.png",
      "splash": {
        "image": "./src/assets/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 44,
      "package": "com.samplefinder.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAywmgeNZsxezVKVV8k3w3v9K8tssxh4mc"
        }
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/splash.png",
          "backgroundColor": "#1a1a2e",
          "resizeMode": "cover",
          "android": {
            "imageWidth": 288
          }
        }
      ],
      "./app.plugin.js",
      "./app.deeplink-plugin.js",
      "./app.firebase-plugin.js",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#1a1a2e",
          "sounds": []
        }
      ]
    ],
    "notification": {
      "icon": "./src/assets/icon.png",
      "color": "#1a1a2e"
    },
    "extra": {
      "eas": {
        "projectId": "559e8cf0-d874-4863-9cea-bab8178cc92c"
      }
    },
    "owner": "jawlon"
  }
}
